<mxfile host="app.diagrams.net">
  <diagram name="Page-1" id="Jba-OmJd3Rd0Y7cP3jaP">
    <mxGraphModel dx="1414" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" mermaidData="{&#xa;  &quot;data&quot;: &quot;graph TB\n    %% --- THEME STYLING CONFIGURATIONS ---\n    classDef client fill:#1e293b,stroke:#38bdf8,stroke-width:2px,color:#f8fafc;\n    classDef supervisor fill:#311042,stroke:#c084fc,stroke-width:3px,color:#f3e8ff;\n    classDef worker fill:#0f172a,stroke:#64748b,stroke-width:2px,color:#e2e8f0;\n    classDef critical_node fill:#14532d,stroke:#4ade80,stroke-width:2px,color:#f0fdf4;\n    classDef engine fill:#7c2d12,stroke:#fb923c,stroke-width:2px,color:#fff7ed;\n    classDef pipeline fill:#0369a1,stroke:#0ea5e9,stroke-width:2px,color:#e0f2fe;\n    classDef storage fill:#1c1917,stroke:#a8a29e,stroke-width:1px,stroke-dasharray: 4 4,color:#f5f5f4;\n\n    %% --- CLIENT INTERFACE LAYER ---\n    subgraph Client_Layer [\&quot;Client Interface Layer\&quot;]\n        UI[\&quot;💻 Streamlit Dashboard&lt;br/&gt;(streamlit_app4.py)\&quot;]:::client\n        API[\&quot;📡 FastAPI Microservices&lt;br/&gt;(POST /chat)\&quot;]:::client\n    end\n\n    %% --- LANGGRAPH CORE ORCHESTRATION ---\n    subgraph Orchestration_Layer [\&quot;Orchestration &amp; State Engine (graph.py)\&quot;]\n        STATE[(\&quot;State Store: AgentState&lt;br/&gt;• messages: List&lt;br/&gt;• db_results: List[DbQueryResult]&lt;br/&gt;• research_data: List&lt;br/&gt;• blog_post: str\&quot;)]:::worker\n        \n        SUPERVISOR{\&quot;🧠 Supervisor Router Node&lt;br/&gt;(Llama-3.3-70B via Groq)\&quot;}:::supervisor\n\n        NODE_RESEARCH[\&quot;🔍 researcher_agent node&lt;br/&gt;(nodes.py)\&quot;]:::worker\n        NODE_DB[\&quot;💾 db_agent node&lt;br/&gt;(nodes.py)\&quot;]:::worker\n        NODE_WRITER[\&quot;✍️ writer_agent node&lt;br/&gt;(nodes.py)\&quot;]:::critical_node\n        END_GRAPH(((🏁 FINISH))):::supervisor\n    end\n\n    %% --- NL2SQL CAPTURE &amp; RE-ACT TOOL EXECUTION SYSTEM ---\n    subgraph Execution_Layer [\&quot;Specialized Backend Execution Engines\&quot;]\n        RAG_CORE[\&quot;⚡ ShortResearchAgent&lt;br/&gt;(agent5_async.py)\&quot;]:::engine\n        REACT_CORE[\&quot;⚙️ AIAgent ReAct Engine&lt;br/&gt;(langchain_agent4.py)&lt;br/&gt;• Evaluates DB Schema Prompt&lt;br/&gt;• Auto-Generates Target SQL Query\&quot;]:::engine\n    end\n\n    %% --- DATA PIPELINE &amp; SERIALIZATION FLOW (DEEP DIVE) ---\n    subgraph Data_Pipeline [\&quot;High-Performance Data Processing Pipeline\&quot;]\n        SQL_GUARD{\&quot;🛡️ AST Security Gateway&lt;br/&gt;(sqlglot Parser)\&quot;}:::critical_node\n        DB_ENGINE[\&quot;⚙️ SQLite Connector&lt;br/&gt;(sqlite3.connect)\&quot;]:::pipeline\n        DF_TRANSFORM[\&quot;🐼 Pandas Transformation Engine&lt;br/&gt;pd.DataFrame(rows, columns)\&quot;]:::pipeline\n        ARROW_TRANSFORM[\&quot;📐 PyArrow Schema Serialization&lt;br/&gt;pa.Table.from_pandas(df)\&quot;]:::pipeline\n    end\n\n    %% --- TARGET OUTPUTS &amp; COLD CACHING ---\n    subgraph Data_Layer [\&quot;Data Caching &amp; Distribution Formats\&quot;]\n        OUT_PARQUET[(\&quot;📦 Apache Parquet Export&lt;br/&gt;(outputs/result.parquet)\&quot;)]:::storage\n        OUT_CSV[(\&quot;📄 Flat CSV Document&lt;br/&gt;(outputs/result.csv)\&quot;)]:::storage\n        OUT_STATE[\&quot;🔄 Structured Pydantic Payload&lt;br/&gt;(DbQueryResult -&gt; state.py)\&quot;]:::worker\n        UI_DATATABLE[\&quot;📊 Interactive UI Table Canvas&lt;br/&gt;(st.dataframe View Matrix)\&quot;]:::client\n    end\n\n    %% --- CORE ARCHITECTURE INTERACTIONS ---\n    UI ==&gt;|1. Dispatch Prompt| STATE\n    API ==&gt;|1. Dispatch Prompt| STATE\n    STATE --&gt; SUPERVISOR\n\n    %% Supervisor Dynamic Allocation Routing\n    SUPERVISOR ==&gt;|Route: Collect Context| NODE_RESEARCH\n    SUPERVISOR ==&gt;|Route: Introspect Database| NODE_DB\n    SUPERVISOR ==&gt;|Route: Final Blog Handoff| NODE_WRITER\n    SUPERVISOR ==&gt;|Route: Woven Output Complete| END_GRAPH\n\n    %% State Mutation Feedback Loop\n    NODE_RESEARCH ==&gt;|Return Appended State| SUPERVISOR\n    NODE_DB ==&gt;|Return Appended State| SUPERVISOR\n    NODE_WRITER ==&gt;|Return Appended State| SUPERVISOR\n\n    %% Core Worker Engine Assignments\n    NODE_RESEARCH -.-&gt; RAG_CORE\n    NODE_DB -. Triggers chat method loop .-&gt; REACT_CORE\n\n    %% --- DETAILED NL2SQL DATA FLOW PIPELINE ---\n    REACT_CORE ==&gt;|2. Generates Raw SQL String| SQL_GUARD\n    \n    SQL_GUARD ==&gt;|Pass: Read-Only Validated| DB_ENGINE\n    SQL_GUARD -. Fail: Mutation Detected .-&gt; NODE_DB\n    \n    DB_ENGINE ==&gt;|3. Extract Row Tuples &amp; Headers| DF_TRANSFORM\n    \n    %% Parallel Data Serialization Paths\n    DF_TRANSFORM ==&gt;|4a. Compress Storage Matrix| ARROW_TRANSFORM\n    DF_TRANSFORM ==&gt;|4b. Render Structural CSV| OUT_CSV\n    DF_TRANSFORM ==&gt;|4c. Construct State Object| OUT_STATE\n    DF_TRANSFORM ==&gt;|4d. Mount Streamlit View Matrix| UI_DATATABLE\n\n    ARROW_TRANSFORM ==&gt;|5. Write Encrypted File| OUT_PARQUET\n    OUT_STATE ==&gt;|6. Inject Back into Context| STATE&quot;,&#xa;  &quot;config&quot;: null&#xa;}" id="2QJ9DD0fUUfNRnbx0dko-1">
