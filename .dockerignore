# Ignore local python virtual environments
env/
venv/
.venv/

# Ignore local database states (since we use a high-performance Named Volume)
chroma_research_db/

# Ignore python compilation artifacts and caches
**/__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/


# Ignore OS overhead
.DS_Store


# Ignore local source control and IDE settings
.git/
.gitignore
.vscode/
.idea/

# Ignore local databases, RAG storage, and logs
*.log
multi_agent_chroma_storage/
chroma/
data/